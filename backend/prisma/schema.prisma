generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  name               String?
  password           String
  role               Role               @default(STAFF)
  employmentType     EmploymentType     @default(PART_TIME)
  branchId           Int?
  branch             Branch?            @relation(fields: [branchId], references: [id])
  hourlyRate         Decimal            @default(0) @db.Decimal(19, 4)
  baseSalary         Decimal            @default(0) @db.Decimal(19, 4)
  orders             Order[]
  transfersRequested StockTransfer[]    @relation("TransferRequestedBy")
  transfersApproved  StockTransfer[]    @relation("TransferApprovedBy")
  auditLogs          AuditLog[]
  shifts             Shift[]
  attendanceRecords  AttendanceRecord[]
  leaveRequests      LeaveRequest[]
  wasteLogs          WasteLog[]
  expenses           Expense[]
  shiftSettlements   ShiftSettlement[]
  payslips           Payslip[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([branchId])
}

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

model Branch {
  id                Int                @id @default(autoincrement())
  name              String
  location          String?
  isCentralKitchen  Boolean            @default(false)
  users             User[]
  orders            Order[]
  inventories       BranchInventory[]
  purchaseOrders    PurchaseOrder[]
  inventoryBatches  InventoryBatch[]
  transfersOut      StockTransfer[]    @relation("TransferFrom")
  transfersIn       StockTransfer[]    @relation("TransferTo")
  productionOrders  ProductionOrder[]
  shifts            Shift[]
  attendanceRecords AttendanceRecord[]
  wasteLogs         WasteLog[]
  expenses          Expense[]
  shiftSettlements  ShiftSettlement[]
  payrollRuns       PayrollRun[]
  equipment         Equipment[]
  journalEntries    JournalEntry[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Ingredient {
  id                       Int                 @id @default(autoincrement())
  name                     String
  unit                     String
  costPerUnit              Decimal             @default(0) @db.Decimal(19, 4)
  primarySupplierId        Int?
  primarySupplier          Supplier?           @relation(fields: [primarySupplierId], references: [id])
  recipeItems              RecipeItem[]
  targetBOMs               ProductionBOM[]     @relation("BOMTarget")
  rawBOMs                  ProductionBOM[]     @relation("BOMRaw")
  productionOrders         ProductionOrder[]
  branchInventories        BranchInventory[]
  purchaseOrderItems       PurchaseOrderItem[]
  inventoryBatches         InventoryBatch[]
  stockTransfers           StockTransfer[]
  wasteLogs                WasteLog[]
  isActive                 Boolean             @default(true)
  modifierGroupsSwapTarget ModifierGroup[]     @relation("ModifierSwapTarget")
  modifierOptionsSwapTo    ModifierOption[]    @relation("ModifierSwapTo")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([primarySupplierId])
}

model BranchInventory {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  stock        Float      @default(0)
  minStock     Int
  updatedAt    DateTime   @updatedAt

  @@unique([branchId, ingredientId])
}

model InventoryBatch {
  id            Int            @id @default(autoincrement())
  branchId      Int
  branch        Branch         @relation(fields: [branchId], references: [id])
  ingredientId  Int
  ingredient    Ingredient     @relation(fields: [ingredientId], references: [id])
  quantity      Float
  expiryDate    DateTime?
  poId          Int?
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  status        BatchStatus    @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([branchId, ingredientId, status])
  @@index([expiryDate])
  @@index([poId])
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

model StockTransfer {
  id            Int            @id @default(autoincrement())
  fromBranchId  Int
  fromBranch    Branch         @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId    Int
  toBranch      Branch         @relation("TransferTo", fields: [toBranchId], references: [id])
  ingredientId  Int
  ingredient    Ingredient     @relation(fields: [ingredientId], references: [id])
  quantity      Float
  status        TransferStatus @default(PENDING)
  requestedById Int
  requestedBy   User           @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById  Int?
  approvedBy    User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([ingredientId])
  @@index([requestedById])
  @@index([approvedById])
}

enum TransferStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELLED
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  action     String
  targetType String // e.g. "InventoryBatch", "Order", "StockTransfer"
  targetId   Int?
  details    String? // JSON string or text details
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Product {
  id          Int          @id @default(autoincrement())
  name        String
  price       Decimal      @db.Decimal(19, 4)
  category    String
  isActive    Boolean      @default(true)
  recipeItems RecipeItem[]
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RecipeItem {
  id           Int        @id @default(autoincrement())
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float

  @@index([productId])
  @@index([ingredientId])
}

model Customer {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  points    Int      @default(0)
  tier      Tier     @default(REGULAR)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Tier {
  REGULAR
  SILVER
  GOLD
  PLATINUM
}

model Promotion {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  description   String
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(19, 4)
  minPurchase   Decimal?     @db.Decimal(19, 4)
  isActive      Boolean      @default(true)
  startDate     DateTime?
  endDate       DateTime?
  orders        Order[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  QR_PROMPTPAY
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
  REFUNDED
}

model Order {
  id                    Int           @id @default(autoincrement())
  totalAmount           Decimal       @db.Decimal(19, 4)
  discountAmount        Decimal       @default(0) @db.Decimal(19, 4)
  netAmount             Decimal       @default(0) @db.Decimal(19, 4)
  taxAmount             Decimal       @default(0) @db.Decimal(19, 4)
  totalCogs             Decimal       @default(0) @db.Decimal(19, 4)
  pointsEarned          Int           @default(0)
  pointsRedeemed        Int           @default(0)
  status                OrderStatus   @default(PENDING)
  paymentMethod         PaymentMethod @default(CASH)
  isTaxInvoiceRequested Boolean       @default(false)
  taxInvoiceName        String?
  taxInvoiceTaxId       String?
  taxInvoiceAddress     String?
  userId                Int
  user                  User          @relation(fields: [userId], references: [id])
  branchId              Int
  branch                Branch        @relation(fields: [branchId], references: [id])
  customerId            Int?
  customer              Customer?     @relation(fields: [customerId], references: [id])
  promotionId           Int?
  promotion             Promotion?    @relation(fields: [promotionId], references: [id])
  queueNumber           Int?
  queueDate             DateTime?     @db.Date
  refundReason          String?
  refundedAt            DateTime?
  items                 OrderItem[]
  createdAt             DateTime      @default(now())

  @@unique([branchId, queueDate, queueNumber])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        Int                 @id @default(autoincrement())
  orderId   Int
  order     Order               @relation(fields: [orderId], references: [id])
  productId Int
  product   Product             @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal             @db.Decimal(19, 4)
  notes     String?
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
}

model ModifierGroup {
  id               Int              @id @default(autoincrement())
  name             String
  category         String?
  sortOrder        Int              @default(0)
  swapIngredientId Int?
  swapIngredient   Ingredient?      @relation("ModifierSwapTarget", fields: [swapIngredientId], references: [id], onDelete: SetNull)
  options          ModifierOption[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([swapIngredientId])
}

model ModifierOption {
  id                 Int                 @id @default(autoincrement())
  groupId            Int
  group              ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name               String
  priceDelta         Decimal             @default(0) @db.Decimal(19, 4)
  isDefault          Boolean             @default(false)
  sortOrder          Int                 @default(0)
  swapToIngredientId Int?
  swapToIngredient   Ingredient?         @relation("ModifierSwapTo", fields: [swapToIngredientId], references: [id], onDelete: SetNull)
  orderItems         OrderItemModifier[]

  @@index([groupId])
  @@index([swapToIngredientId])
}

model OrderItemModifier {
  id          Int            @id @default(autoincrement())
  orderItemId Int
  orderItem   OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionId    Int
  option      ModifierOption @relation(fields: [optionId], references: [id])
  optionName  String
  priceDelta  Decimal        @db.Decimal(19, 4)

  @@index([orderItemId])
}

model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  contactEmail   String?
  phone          String?
  purchaseOrders PurchaseOrder[]
  ingredients    Ingredient[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id               Int                 @id @default(autoincrement())
  poNumber         String              @unique
  branchId         Int
  branch           Branch              @relation(fields: [branchId], references: [id])
  supplierId       Int
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  status           POStatus            @default(PENDING)
  isAutoGenerated  Boolean             @default(false)
  items            PurchaseOrderItem[]
  inventoryBatches InventoryBatch[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

enum POStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
}

model PurchaseOrderItem {
  id                Int           @id @default(autoincrement())
  poId              Int
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id])
  ingredientId      Int
  ingredient        Ingredient    @relation(fields: [ingredientId], references: [id])
  quantityRequested Float
  unitPrice         Decimal       @db.Decimal(19, 4)

  @@index([poId])
  @@index([ingredientId])
}

model Shift {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch      @relation(fields: [branchId], references: [id])
  startTime DateTime
  endTime   DateTime
  status    ShiftStatus @default(SCHEDULED)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([branchId])
  @@index([userId])
}

enum ShiftStatus {
  SCHEDULED
  COMPLETED
  ABSENT
  CANCELLED
}

model LeaveRequest {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  type      LeaveType
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

enum LeaveType {
  SICK
  ANNUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceRecord {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  branchId   Int
  branch     Branch    @relation(fields: [branchId], references: [id])
  clockIn    DateTime  @default(now())
  clockOut   DateTime?
  totalHours Float? // Calculated on clock out
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([branchId])
}

model WasteLog {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  reason       String
  recordedById Int
  recordedBy   User       @relation(fields: [recordedById], references: [id])
  createdAt    DateTime   @default(now())

  @@index([branchId])
  @@index([createdAt])
  @@index([ingredientId])
  @@index([recordedById])
}

model Expense {
  id           Int      @id @default(autoincrement())
  branchId     Int
  branch       Branch   @relation(fields: [branchId], references: [id])
  amount       Decimal  @db.Decimal(19, 4)
  category     String
  description  String?
  recordedById Int
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([branchId])
  @@index([createdAt])
  @@index([recordedById])
}

model ShiftSettlement {
  id                 Int              @id @default(autoincrement())
  branchId           Int
  branch             Branch           @relation(fields: [branchId], references: [id])
  date               DateTime         @default(now()) @db.Date
  expectedCash       Decimal          @default(0) @db.Decimal(19, 4)
  actualCash         Decimal          @default(0) @db.Decimal(19, 4)
  expectedCreditCard Decimal          @default(0) @db.Decimal(19, 4)
  actualCreditCard   Decimal          @default(0) @db.Decimal(19, 4)
  expectedQR         Decimal          @default(0) @db.Decimal(19, 4)
  actualQR           Decimal          @default(0) @db.Decimal(19, 4)
  difference         Decimal          @default(0) @db.Decimal(19, 4)
  status             SettlementStatus @default(PENDING)
  submittedById      Int
  submittedBy        User             @relation(fields: [submittedById], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([branchId])
  @@index([submittedById])
}

enum SettlementStatus {
  PENDING
  APPROVED
  REJECTED
}

model PayrollRun {
  id        Int           @id @default(autoincrement())
  month     Int
  year      Int
  status    PayrollStatus @default(DRAFT)
  branchId  Int?
  branch    Branch?       @relation(fields: [branchId], references: [id])
  payslips  Payslip[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([branchId])
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model Payslip {
  id              Int        @id @default(autoincrement())
  payrollRunId    Int
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id])
  userId          Int
  user            User       @relation(fields: [userId], references: [id])
  standardHours   Float      @default(0)
  otHours         Float      @default(0)
  basePay         Decimal    @default(0) @db.Decimal(19, 4)
  otPay           Decimal    @default(0) @db.Decimal(19, 4)
  bonuses         Decimal    @default(0) @db.Decimal(19, 4)
  grossPay        Decimal    @default(0) @db.Decimal(19, 4)
  taxDeduction    Decimal    @default(0) @db.Decimal(19, 4)
  socialSecurity  Decimal    @default(0) @db.Decimal(19, 4)
  otherDeductions Decimal    @default(0) @db.Decimal(19, 4)
  netPay          Decimal    @default(0) @db.Decimal(19, 4)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([payrollRunId])
  @@index([userId])
}

model Equipment {
  id                  Int              @id @default(autoincrement())
  branchId            Int
  branch              Branch           @relation(fields: [branchId], references: [id])
  name                String
  type                EquipmentType
  serialNumber        String?
  status              EquipmentStatus  @default(ACTIVE)
  purchaseDate        DateTime?
  warrantyExpiry      DateTime?
  nextMaintenanceDate DateTime?
  maintenanceLogs     MaintenanceLog[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([branchId])
}

enum EquipmentType {
  ESPRESSO_MACHINE
  GRINDER
  BLENDER
  POS_SYSTEM
  REFRIGERATOR
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  BROKEN
  RETIRED
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  description String
  cost        Decimal   @default(0) @db.Decimal(19, 4)
  performedBy String? // External technician or internal staff name
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([equipmentId])
}

// ==========================================
// ACCOUNTING (GENERAL LEDGER)
// ==========================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id          Int                @id @default(autoincrement())
  code        String             @unique // e.g. "1010"
  name        String // e.g. "Cash"
  type        AccountType
  description String?
  isActive    Boolean            @default(true)
  lines       JournalEntryLine[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model JournalEntry {
  id          Int                @id @default(autoincrement())
  branchId    Int?
  branch      Branch?            @relation(fields: [branchId], references: [id])
  date        DateTime           @default(now()) @db.Date
  reference   String? // e.g. "PO-1234", "ORD-999"
  description String // e.g. "Sales Revenue for order 999"
  status      JournalStatus      @default(POSTED)
  lines       JournalEntryLine[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([date])
  @@index([reference])
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalEntryLine {
  id             Int          @id @default(autoincrement())
  journalEntryId Int
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id])
  accountId      Int
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(19, 4)
  credit         Decimal      @default(0) @db.Decimal(19, 4)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
}

// ==========================================
// CENTRAL KITCHEN (PRODUCTION)
// ==========================================

model ProductionBOM {
  id                 Int        @id @default(autoincrement())
  targetIngredientId Int
  targetIngredient   Ingredient @relation("BOMTarget", fields: [targetIngredientId], references: [id])
  rawIngredientId    Int
  rawIngredient      Ingredient @relation("BOMRaw", fields: [rawIngredientId], references: [id])
  quantityNeeded     Float // Amount of raw ingredient needed to produce 1 unit of target
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([targetIngredientId, rawIngredientId])
  @@index([rawIngredientId])
}

enum ProductionStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrder {
  id                 Int              @id @default(autoincrement())
  orderNumber        String           @unique
  branchId           Int
  branch             Branch           @relation(fields: [branchId], references: [id])
  targetIngredientId Int
  targetIngredient   Ingredient       @relation(fields: [targetIngredientId], references: [id])
  quantityToProduce  Float
  status             ProductionStatus @default(DRAFT)
  actualCost         Decimal          @default(0) @db.Decimal(19, 4)
  plannedStartDate   DateTime?
  completedAt        DateTime?
  createdByUserId    Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([branchId])
  @@index([status])
  @@index([targetIngredientId])
  @@index([createdByUserId])
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model OutboxEvent {
  id          Int          @id @default(autoincrement())
  eventType   String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
}
