# Public browser URL for the backend API.
# Local dev:
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Optional server-side URL used by Next.js server components/actions.
# Docker Compose should use the backend service name:
# INTERNAL_API_URL="http://backend:3000"
# Vercel/Railway split deploys can usually omit this and use NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=""
# Backend API (NestJS default port)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public app URL — used for Open Graph / metadata
NEXT_PUBLIC_APP_URL=http://localhost:3001

# GitHub repo link on the login page
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/nkieu-config/branchbrew-cafe-erp-project

# Playwright E2E (optional — defaults work for local dev)
# PLAYWRIGHT_BASE_URL=http://localhost:3001
# PLAYWRIGHT_SKIP_WEBSERVER=1
# E2E_EMAIL=manager@branchbrew.dev
# E2E_PASSWORD=password123
