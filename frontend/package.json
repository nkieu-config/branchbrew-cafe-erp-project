{
  "name": "branchbrew-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "analyze:turbo": "next experimental-analyze",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci-local": "PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_BASE_URL=http://localhost:3001 playwright test",
    "generate:api": "openapi-typescript ../backend/openapi.json -o src/types/generated/api.d.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "ci:check": "npm run type-check && npm run lint && npm run test:cov && NEXT_PUBLIC_API_URL=http://localhost:3000 npm run build",
    "ci:check:push": "npm run type-check && npm run lint && npm run test"
  },
  "dependencies": {
    "@erp/types": "*",
    "@ant-design/icons": "^6.3.2",
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.101.0",
    "antd": "^6.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-to-print": "^3.3.0",
    "recharts": "^3.9.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
