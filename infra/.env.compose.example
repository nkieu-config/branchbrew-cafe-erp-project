# Copy to infra/.env.compose for local docker-compose:
#   cp infra/.env.compose.example infra/.env.compose
#
# Not used by backend dev (.env) — only for:
#   npm run docker:up
JWT_SECRET=change-me-local-dev-only

# Local compose browser URL. Server-side frontend fetches use INTERNAL_API_URL from docker-compose.yml.
NEXT_PUBLIC_API_URL=http://localhost:3000
