# Copy to infra/.env.compose for local docker-compose:
#   cp infra/.env.compose.example infra/.env.compose
#
# Not used by backend dev (.env) — only for:
#   npm run docker:up          (local dev — backend Dockerfile target: development)
#   npm run docker:up:prod     (production image — requires CORS_ORIGIN without localhost)
JWT_SECRET=change-me-local-dev-only

# Local compose browser URL. Server-side frontend fetches use INTERNAL_API_URL from docker-compose.yml.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Local Postgres (used by docker-compose.yml — not exposed in docker-compose.prod.yml)
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_db

# Required for npm run docker:up:prod (see infra/.env.supabase.example for full production values):
# CORS_ORIGIN=https://your-frontend.example.com
# DATABASE_URL=postgresql://user:password@db:5432/erp_db?schema=public
