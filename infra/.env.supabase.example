# Portfolio production/demo deployment with Supabase Postgres.
# Copy values into your hosting provider's secret manager; do not commit real values.

# Runtime app connection: Supabase transaction pooler (usually port 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Migration connection: Supabase direct/session connection (usually port 5432)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# Frontend deployment origin, comma-separated if you have preview domains.
CORS_ORIGIN="https://your-frontend.example.com"

# COOKIE_SAME_SITE=none

# Business-day timezone for POS queue resets.
BUSINESS_TIMEZONE="UTC"

# Only set these when intentionally wiping and reseeding a disposable demo DB.
# ALLOW_DEMO_SEED=true
# DEMO_SEED_CONFIRM=WIPE_DEMO_DATABASE
