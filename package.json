{
  "name": "erp",
  "version": "1.0.0",
  "description": "Enterprise ERP Root",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "generate:types": "node scripts/generate-enums.mjs",
    "openapi:export": "npm run openapi:export --workspace=backend",
    "prepare": "husky",
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "docker:up": "docker compose -f infra/docker-compose.yml --env-file infra/.env.compose up --build",
    "docker:up:prod": "docker compose -f infra/docker-compose.prod.yml --env-file infra/.env.compose up --build",
    "docker:down": "docker compose -f infra/docker-compose.yml --env-file infra/.env.compose down",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "migrate": "npm run migrate:deploy --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend",
    "audit:ci": "npm audit --audit-level=critical && node scripts/security-audit.mjs",
    "test": "npm run test --workspaces --if-present",
    "test:e2e:backend": "npm run test:e2e --workspace=backend",
    "test:e2e:frontend": "npm run test:e2e --workspace=frontend",
    "test:e2e:ci-local": "./scripts/run-e2e-ci-local.sh",
    "ci:check": "npm run ci:check --workspaces --if-present",
    "ci:check:push": "npm run ci:check:push --workspaces --if-present"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "workspaces": [
    "frontend",
    "backend",
    "packages/types"
  ]
}
